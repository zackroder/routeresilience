{
    "name": "transit-detour-manager",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "dev:server": "tsx watch src/server/index.ts",
        "dev:client": "vite src/client --config vite.config.ts",
        "build": "vite build src/client --config vite.config.ts && tsc --noEmit",
        "start": "tsx src/server/index.ts"
    },
    "dependencies": {
        "adm-zip": "^0.5.10",
        "better-sqlite3": "^12.6.2",
        "cors": "^2.8.5",
        "csv-parse": "^5.5.0",
        "express": "^4.21.0",
        "protobufjs": "^7.4.0",
        "unzipper": "^0.12.5"
    },
    "devDependencies": {
        "@types/adm-zip": "^0.5.5",
        "@types/better-sqlite3": "^7.6.13",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/unzipper": "^0.10.11",
        "concurrently": "^9.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.5.0",
        "vite": "^5.4.0"
    }
}
